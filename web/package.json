{
  "name": "hedgemony-web",
  "version": "0.0.1",
  "private": true,
  "description": "Web UI for Hedgemony: Takeoff — a 7-faction AI-race wargame.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "ENABLE_CLASSIC=1 NEXT_PUBLIC_ENABLE_CLASSIC=1 turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "parse:cards": "pnpm --filter @hedgemony/spec parse",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "pnpm --filter @hedgemony/db migrate",
    "db:generate": "pnpm --filter @hedgemony/db generate",
    "db:studio": "pnpm --filter @hedgemony/db studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.5.4",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
